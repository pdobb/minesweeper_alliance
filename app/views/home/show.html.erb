<% title("War Room") %>

<% @view.welcome_banner(context: layout).tap do |welcome_banner| %>
  <% if welcome_banner.show? %>
    <%= turbo_frame_tag(
          welcome_banner.turbo_frame_name,
          class: "container mx-auto") do %>
      <%= render("layouts/banner", banner: welcome_banner.banner) %>
    <% end %>
  <% end %>
<% end %>

<% @view.container.tap do |container| %>
  <%= render(container.partial_path, container:) %>
<% end %>
